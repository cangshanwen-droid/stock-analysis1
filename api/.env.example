CORS_ALLOW_ORIGINS=*
TOKEN_SECRET=replace-with-a-long-random-secret
TOKEN_TTL_SECONDS=28800
ENABLE_ORDER_WRITES=false
ENABLE_MARKET_WRITES=false
ENABLE_ADMIN_WRITES=false
